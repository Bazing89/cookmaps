# Bunny Stream — Stream dashboard → your library → API
# IMPORTANT: use the per-library Stream API key (UUID), NOT Account → API key.
# Library ID is the numeric ID in the library URL / settings (must match that library).
EXPO_PUBLIC_BUNNY_STREAM_API_KEY=
EXPO_PUBLIC_BUNNY_STREAM_LIBRARY_ID=

# Optional — auto-detected from library/videos when omitted
EXPO_PUBLIC_BUNNY_STREAM_CDN_HOSTNAME=

# Optional — required when Bunny "Block direct URL file access" is enabled
# EXPO_PUBLIC_BUNNY_STREAM_EMBED_REFERER=https://iframe.mediadelivery.net/

# Google Maps / Places Geocoding API (web + iOS + Android)
# Enable: Maps JavaScript API, Geocoding API, Maps SDK for Android, Maps SDK for iOS
# Localhost: add http://localhost:*/* to HTTP referrer restrictions (web key)
# Mobile: restrict by bundle ID com.cookmapz.app (iOS) and package + SHA-1 (Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase — Project Settings → API (anon/public key only; never use service_role in the app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — scripts/seed_demo_content.mjs only (Project Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=
# COOKMAPZ_DEMO_EMAIL=cookmapz.showcase@gmail.com
# COOKMAPZ_DEMO_PASSWORD=CookMapz2026!Showcase
