# Bunny Stream — Stream dashboard → your library → API
# IMPORTANT: use the per-library Stream API key (UUID), NOT Account → API key.
# Library ID is the numeric ID in the library URL / settings (must match that library).
EXPO_PUBLIC_BUNNY_STREAM_API_KEY=
EXPO_PUBLIC_BUNNY_STREAM_LIBRARY_ID=

# Optional — auto-detected from library/videos when omitted
EXPO_PUBLIC_BUNNY_STREAM_CDN_HOSTNAME=

# Optional — required when Bunny "Block direct URL file access" is enabled
# EXPO_PUBLIC_BUNNY_STREAM_EMBED_REFERER=https://iframe.mediadelivery.net/
