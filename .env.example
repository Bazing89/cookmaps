# Bunny Stream — Stream dashboard → your library → API
# IMPORTANT: use the per-library Stream API key (UUID), NOT Account → API key.
# Library ID is the numeric ID in the library URL / settings (must match that library).
EXPO_PUBLIC_BUNNY_STREAM_API_KEY=
EXPO_PUBLIC_BUNNY_STREAM_LIBRARY_ID=

# Live streaming library (RTMP ingest + HLS playback for ticketed live cooks)
EXPO_PUBLIC_BUNNY_LIVE_LIBRARY_ID=706984
# Optional — OBS/Larix RTMP server URL (stream key comes from Bunny Live API)
# EXPO_PUBLIC_BUNNY_LIVE_RTMP_URL=rtmp://live.bunnycdn.com/live

# Optional — auto-detected from library/videos when omitted
EXPO_PUBLIC_BUNNY_STREAM_CDN_HOSTNAME=

# Optional — required when Bunny "Block direct URL file access" is enabled
# EXPO_PUBLIC_BUNNY_STREAM_EMBED_REFERER=https://iframe.mediadelivery.net/

# Google Maps / Places Geocoding API (web + iOS + Android)
# Enable: Maps JavaScript API, Geocoding API, Maps SDK for Android, Maps SDK for iOS
# Localhost: add http://localhost:*/* to HTTP referrer restrictions (web key)
# Mobile: restrict by bundle ID com.cookmapz.app (iOS) and package + SHA-1 (Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase — Project Settings → API (anon/public key only; never use service_role in the app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Use a production-ready SMTP server (required to deploy custom auth email templates on hosted Supabase)
# Resend: create API key at https://resend.com — verify cookmapz.app domain first
# RESEND_API_KEY=re_...
# Then uncomment [auth.email.smtp] in supabase/config.toml and run: npx supabase config push
#
# [auth.email.smtp]
# enabled = true
# host = "smtp.resend.com"
# port = 587
# user = "resend"
# pass = "env(RESEND_API_KEY)"
# admin_email = "noreply@cookmapz.app"
# sender_name = "CookMapz"

# Optional — scripts/seed_demo_content.mjs only (Project Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=
#
# Supabase Edge Function secrets (delete-account) — set on hosted project, not in the Expo app:
#   npx supabase secrets set BUNNY_STREAM_API_KEY=... BUNNY_STREAM_LIBRARY_ID=...
# Then deploy: npx supabase functions deploy delete-account
# COOKMAPZ_DEMO_EMAIL=cookmapz.showcase@gmail.com
# COOKMAPZ_DEMO_PASSWORD=CookMapz2026!Showcase

# Cloudflare Workers (wrangler.jsonc in repo root)
#
# dist/ is NOT in git — you must export the web app before wrangler deploy.
#
# Option A (recommended — one command in Cloudflare Deploy command):
#   npm run deploy:cloudflare
#
# Option B (split build + deploy in dashboard):
#   Build command:  npm run build:web
#   Deploy command: npx wrangler deploy
#
# Dashboard → Workers & Pages → cookmapz → Settings → Builds
#   Node version: 22
#
# Set ALL EXPO_PUBLIC_* vars below in Cloudflare → Settings → Variables (Build).
# Expo embeds them at build time — changing them requires a new deploy.
# Do NOT use public/_redirects with /* → /index.html (loops on Workers).
